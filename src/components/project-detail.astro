---
import { Image, getImage } from "astro:assets";
import { render } from "astro:content";
import H1 from "./h1.astro";
import Prose from "./prose.astro";
import Gallery from "./gallery";
import ProjectMeta from "./project-meta.astro";
import { useTranslations, localizePath, type Locale } from "../i18n/ui";
import type { Project, ProjectEn } from "../lib/projects";

interface Props {
    project: Project;
    english?: ProjectEn;
    locale: Locale;
}

const { project, english, locale } = Astro.props;
const t = useTranslations(locale);

// English pages render the translated body when present, else fall back to Czech.
const entry = locale === "en" && english ? english : project;
const data = entry.data;
const { Content } = await render(entry);

// Pre-optimise gallery images so the lightbox island gets ready-to-use URLs.
const galleryImages = await Promise.all(
    project.data.gallery.map(async (item) => {
        const optimised = await getImage({ src: item.src, width: 1600 });
        return { src: optimised.src, alt: item.alt || data.title };
    }),
);
---

<section class="p-4 sm:pt-8 sm:px-12 pb-20 min-h-dvh">
    <a
        href={localizePath("/projects", locale)}
        class="text-sm text-zinc-400 hover:text-white underline underline-offset-4 decoration-zinc-600 hover:decoration-zinc-300"
    >
        {t("projects.back")}
    </a>

    <div class="mt-4 sm:mt-6">
        <H1 className="text-4xl md:text-5xl xl:text-6xl">{data.title}</H1>
        <p class="mt-3 text-base text-zinc-400 text-balance">{data.description}</p>
    </div>

    <Image
        src={project.data.cover}
        alt={project.data.coverAlt || data.title}
        class="mt-6 w-full max-h-[28rem] object-center object-cover rounded-xl shadow-lg"
    />

    <ProjectMeta data={data} locale={locale} />

    <div class="mt-8">
        <Prose>
            <Content />
        </Prose>
    </div>

    {
        galleryImages.length > 0 && (
            <div class="mt-12">
                <h2 class="text-lg text-zinc-400 font-medium">{t("project.gallery")}</h2>
                <Gallery images={galleryImages} closeLabel={t("gallery.close")} client:visible />
            </div>
        )
    }
</section>
