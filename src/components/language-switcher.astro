---
import { getLocaleFromUrl, switchLocalePath, locales } from "../i18n/ui";

const current = getLocaleFromUrl(Astro.url);
const target = locales.find((l) => l !== current) ?? current;
const href = switchLocalePath(Astro.url.pathname, target);
const label = target.toUpperCase();
---

<a
    href={href}
    hreflang={target}
    class="hidden sm:flex fixed top-6 right-6 z-50 items-center justify-center min-w-9 h-9 px-3 text-sm font-medium text-zinc-200 bg-zinc-900/60 hover:bg-zinc-800/80 backdrop-blur-md rounded-full ring-1 ring-zinc-100/10 hover:text-white transition-colors duration-300 focus-visible:outline-2 outline-offset-2 outline-zinc-100/50"
    aria-label={`Switch language to ${label}`}
>
    {label}
</a>
