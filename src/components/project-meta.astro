---
import { useTranslations, type Locale } from "../i18n/ui";
import type { Project } from "../lib/projects";

interface Props {
    data: Project["data"];
    locale?: Locale;
}

const { data, locale = "cs" } = Astro.props;
const t = useTranslations(locale);
const { date, role, category, tools, links } = data;

const formattedDate = date
    ? new Intl.DateTimeFormat(locale === "en" ? "en-US" : "cs-CZ", {
          year: "numeric",
          month: "long",
      }).format(date)
    : null;

type Row = { label: string; value: string };
const rows: Row[] = [
    formattedDate && { label: t("project.date"), value: formattedDate },
    role && { label: t("project.role"), value: role },
    category && { label: t("project.category"), value: category },
    tools.length > 0 && { label: t("project.tools"), value: tools.join(", ") },
].filter(Boolean) as Row[];
---

{
    (rows.length > 0 || links.length > 0) && (
        <dl class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 border-t border-zinc-800 pt-6">
            {rows.map((row) => (
                <div>
                    <dt class="text-xs uppercase tracking-wide text-zinc-600">{row.label}</dt>
                    <dd class="text-sm text-zinc-300">{row.value}</dd>
                </div>
            ))}

            {links.length > 0 && (
                <div class="sm:col-span-2">
                    <dt class="text-xs uppercase tracking-wide text-zinc-600">{t("project.links")}</dt>
                    <dd class="mt-1 flex flex-wrap gap-x-4 gap-y-1">
                        {links.map((link) => (
                            <a
                                href={link.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-sm text-zinc-300 underline underline-offset-4 decoration-zinc-600 hover:text-white hover:decoration-zinc-300"
                            >
                                {link.label}
                            </a>
                        ))}
                    </dd>
                </div>
            )}
        </dl>
    )
}
