---
import H1 from "../components/h1.astro";
import ProjectsGrid from "../components/projects-grid.astro";
import InfoLayout from "../layouts/InfoLayout.astro";
import { getLocalizedProjectCards } from "../lib/projects";
import { useTranslations } from "../i18n/ui";

const t = useTranslations("cs");
const cards = await getLocalizedProjectCards("cs");
---

<InfoLayout title="Projekty — Richard Šiser" description="Výběr inženýrských projektů Richarda Šisera." locale="cs">
     <div class="p-4 sm:pt-8 sm:px-12 pb-20 min-h-dvh">
          <H1>{t("projects.title")}</H1>
          <ProjectsGrid cards={cards} locale="cs" />
     </div>
</InfoLayout>
