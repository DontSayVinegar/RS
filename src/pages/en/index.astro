---
import H1 from "../../components/h1.astro";
import Link from "../../components/link.astro";
import Navigation, { type NavItem } from "../../components/navigation";
import RootLayout from "../../layouts/RootLayout.astro";
import WarpBackground from "../../components/warp-background";
import AvailableForWork from "../../components/available.astro";
import { useTranslations, localizePath, switchLocalePath } from "../../i18n/ui";

const locale = "en";
const t = useTranslations(locale);

const navItems: NavItem[] = [
	{ href: switchLocalePath(Astro.url.pathname, "cs"), label: t("lang.switchFull"), icon: "language" },
	{ href: localizePath("/about", locale), label: t("nav.services"), icon: "info" },
	{ href: localizePath("/contact", locale), label: t("nav.contact"), icon: "smiley" },
];
---

<RootLayout locale={locale}>
	<main>
		<div class="group relative w-full min-h-dvh flex items-center justify-center">
			<div class="absolute w-full h-dvh -z-10">
				<WarpBackground
					color1="#09090b"
					color2="#27272a"
					color3="#52525b"
					speed={0.6}
					swirl={0.5}
					swirlIterations={10}
					shapeScale={0.3}
					client:load
				/>
			</div>

			<div class="p-4 sm:p-8 absolute w-full h-dvh flex flex-col justify-between z-10">
				<div>
					<H1 size="large"> Richard <br /> Šiser </H1>
				</div>

				<div>
					<AvailableForWork className="py-4" label={t("available")} />
					<div class="mb-2 sm:mb-4 flex items-center justify-between">
						<div class="flex items-center gap-4">
							<Link href="mailto:richardsiser@gmail.com">{t("nav.contactCta")}</Link>
							<Link href={localizePath("/projects", locale)} variant="secondary">{t("nav.projects")}</Link>
						</div>

						<Navigation items={navItems} closeLabel={t("nav.close")} client:load>
							<Link href={localizePath("/about", locale)} variant="secondary">{t("nav.services")}</Link>
							<Link href={localizePath("/contact", locale)} variant="secondary">{t("nav.contact")}</Link>
						</Navigation>
					</div>
				</div>
			</div>
		</div>
	</main>
</RootLayout>
