---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import H1 from "../../components/h1.astro";
import Prose from "../../components/prose.astro";
import InfoLayout from "../../layouts/InfoLayout.astro";

export const prerender = true;

export async function getStaticPaths() {
    const projects = await getCollection("projects");

    return projects.map((project) => ({
        params: {
            slug: project.data.slug
        },
        props: { project },
    }));
}

const { project } = Astro.props;

if (project === undefined) {
    return new Response("Project not found", { status: 404 });
}

const { Content } = await render(project);
---

<InfoLayout title={project.data.title} description={project.data.description}>
    <section class="p-4 sm:pt-8 sm:px-12 pb-20 min-h-dvh">
        <a href="/projects" class="text-sm text-zinc-400 hover:text-white underline underline-offset-4 decoration-zinc-600 hover:decoration-zinc-300">
            &larr; Zpět na projekty
        </a>

        <div class="mt-4 sm:mt-6">
            <H1 className="text-4xl md:text-5xl xl:text-6xl">{project.data.title}</H1>
            <p class="mt-3 text-base text-zinc-400 text-balance">{project.data.description}</p>
        </div>

        <Image
            src={project.data.cover}
            alt={project.data.coverAlt || project.data.title}
            class="mt-6 w-full max-h-[28rem] object-center object-cover rounded-xl shadow-lg"
        />

        <div class="mt-8">
            <Prose>
                <Content />
            </Prose>
        </div>

        {
            project.data.gallery.length > 0 && (
                <div class="mt-12">
                    <h2 class="text-lg text-zinc-400 font-medium">Galerie</h2>
                    <ul class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {project.data.gallery.map((item) => (
                            <li>
                                <Image
                                    src={item.src}
                                    alt={item.alt || project.data.title}
                                    class="w-full aspect-[4/3] object-center object-cover rounded-lg shadow-lg"
                                />
                            </li>
                        ))}
                    </ul>
                </div>
            )
        }
    </section>
</InfoLayout>
