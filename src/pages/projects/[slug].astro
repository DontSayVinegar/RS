---
import { getImage } from "astro:assets";
import ProjectDetail from "../../components/project-detail.astro";
import InfoLayout from "../../layouts/InfoLayout.astro";
import { getVisibleProjects } from "../../lib/projects";

export const prerender = true;

export async function getStaticPaths() {
    const projects = await getVisibleProjects();

    return projects.map((project) => ({
        params: { slug: project.data.slug },
        props: { project },
    }));
}

const { project } = Astro.props;
const ogImage = await getImage({ src: project.data.cover, format: "jpg", width: 1200, height: 630 });
---

<InfoLayout
    title={`${project.data.title} — Richard Šiser`}
    description={project.data.description}
    image={ogImage.src}
    locale="cs"
>
    <ProjectDetail project={project} locale="cs" />
</InfoLayout>
